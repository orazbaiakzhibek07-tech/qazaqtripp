# QazaqTrip Backend — .env мысалы
# Бұл файлды .env деп көшіріп, мәндерді өзіңіздікімен алмастырыңыз

# MongoDB
MONGO_URI=mongodb://localhost:27017/qazaqtrip

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Session
SESSION_SECRET=your-session-secret-change-this

# GitHub OAuth
# https://github.com/settings/developers сайтынан алыңыз
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Frontend URL (CORS үшін)
CLIENT_URL=http://localhost:3000

# Port
PORT=5000

# Environment
NODE_ENV=development
