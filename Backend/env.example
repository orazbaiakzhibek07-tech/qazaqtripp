# QazaqTrip Backend — .env мысалы
# Бұл файлды .env деп көшіріп, мәндерді өзіңіздікімен алмастырыңыз

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.pra3lzh.mongodb.net/qazaqtrip?appName=Cluster0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Session
SESSION_SECRET=your-session-secret-change-this

# GitHub OAuth
# https://github.com/settings/developers сайтынан алыңыз
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://qazaqtripp-production-aee6.up.railway.app/api/auth/github/callback

# Frontend URL (CORS үшін)
CLIENT_URL=https://qazaqtripp.vercel.app

# Port
PORT=8080

# Environment
NODE_ENV=development
